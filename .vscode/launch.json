{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Streamlit",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "chatbot_app.py",
                "--server.port", "8501",
                "--server.fileWatcherType", "none"
            ],
            "console": "integratedTerminal"
        }
    ]
}